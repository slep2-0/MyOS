# ==============================================================================
# MTDLL Build System (System Tools)
# ==============================================================================

# --- Configuration ------------------------------------------------------------

# Default to MTDLL since this is the mtdllmakefile
TYPE ?= MTDLL
PROJ_NAME = mtdll

# Sources specific to MTDLL
SRCS = programs/mtdll/dllmain.c \
       syscalls/syscalls.asm \
       programs/mtdll/file.c \
       programs/mtdll/generic.c \
       programs/mtdll/memory.c \
       programs/mtdll/process.c \
       programs/mtdll/string.c \
       programs/mtdll/thread.c \
       programs/mtdll/includes/export_table.S \
       programs/mtdll/ldr/procldr.c \
       programs/mtdll/ldr/thrdldr.c \
	   programs/mtdll/error.c \
	   programs/mtdll/synch.c \
	   programs/mtdll/apcdispatch.asm \
	   programs/mtdll/print.c

# --- Toolchain (System Defaults) ----------------------------------------------
# Using standard PATH tools (same as build_mtexe.sh)

CC      = gcc
LD      = ld
OBJCOPY = objcopy
NASM    = nasm
AS      = as
XXD     = xxd

BUILD_DIR = build/user

# --- Logic: Select Linker Script ----------------------------------------------

ifeq ($(TYPE),MTEXE)
    LDSCRIPT = mtexe.ld
    OUT_EXT  = mtexe
    $(info [BUILD-MODE] Building Executable (MTEXE))
else ifeq ($(TYPE),MTDLL)
    LDSCRIPT = mtdll.ld
    OUT_EXT  = mtdll
    $(info [BUILD-MODE] Building Library (MTDLL))
else
    $(error Invalid TYPE specified. Use TYPE=MTEXE or TYPE=MTDLL)
endif

FINAL_OUT = $(BUILD_DIR)/$(PROJ_NAME).$(OUT_EXT)

# --- Flags --------------------------------------------------------------------

# Compiler Flags
# -m64: Enforce 64-bit
# -I...: Add include paths for mtdll headers
CFLAGS = -std=gnu11 \
         -m64 -ffreestanding -nostdlib -fno-builtin -c \
         -fdiagnostics-color=always \
         -Wall -Wextra -Wno-unused-function \
         -mno-red-zone -fno-pie -fPIC \
         -Iprograms/mtdll/includes \
         -Iheaders -MMD -MP -O0 -g \
         -fdebug-prefix-map="/home/kali/Desktop/Operating System=C:/Users/matanel/Desktop/Projects/KernelDevelopment"

# Linker Flags
LDFLAGS = -shared -Bsymbolic --no-undefined -T $(LDSCRIPT) -m elf_x86_64

# Assembly Flags (NASM)
ASMFLAGS = -f elf64

# --- Bootstrapping Files ------------------------------------------------------

HEADER_SRC = header.S
CRT0_SRC   = crt0.S

HEADER_OBJ = $(BUILD_DIR)/header.o
CRT0_OBJ   = $(BUILD_DIR)/crt0.o

# --- Object Calculation -------------------------------------------------------

OBJS = $(SRCS:%=$(BUILD_DIR)/%.o)

# --- Targets ------------------------------------------------------------------

.PHONY: all clean dump

all: $(FINAL_OUT)

# 1. Create Build Directory
$(BUILD_DIR):
	@mkdir -p $(BUILD_DIR)
	@mkdir -p $(dir $(OBJS))

# 2. Compile/Assemble Header & CRT0
$(HEADER_OBJ): $(HEADER_SRC) | $(BUILD_DIR)
	@echo "  [AS]  $<"
	@$(AS) -o $@ $<

$(CRT0_OBJ): $(CRT0_SRC) | $(BUILD_DIR)
	@echo "  [AS]  $<"
	@$(AS) -o $@ $<

# 3. Compile C Sources
$(BUILD_DIR)/%.c.o: %.c | $(BUILD_DIR)
	@echo "  [CC]  $<"
	@mkdir -p $(dir $@)
	@$(CC) $(CFLAGS) $< -o $@

# 4. Assemble NASM Sources (.asm)
$(BUILD_DIR)/%.asm.o: %.asm | $(BUILD_DIR)
	@echo "  [NASM] $<"
	@mkdir -p $(dir $@)
	@$(NASM) $(ASMFLAGS) -o $@ $<

# 5. Assemble GAS Sources (.S)
$(BUILD_DIR)/%.S.o: %.S | $(BUILD_DIR)
	@echo "  [AS]  $<"
	@mkdir -p $(dir $@)
	@$(CC) $(CFLAGS) -o $@ $<

# 6. Link & Convert
# Change the final linking target to omit $(CRT0_OBJ)
$(FINAL_OUT): $(HEADER_OBJ) $(OBJS)
	@echo "  [LD]  Linking -> $(BUILD_DIR)/mtdll_temp.elf"
	@$(LD) $(LDFLAGS) -o $(BUILD_DIR)/mtdll_temp.elf $(HEADER_OBJ) $(OBJS)
	@echo "  [OBJ] Converting -> $@"
	@$(OBJCOPY) -O binary $(BUILD_DIR)/mtdll_temp.elf $@
	@echo "Build succeeded: $@"

# Utility: Hex dump first 8 lines
dump: $(FINAL_OUT)
	@echo "Header bytes:"
	@$(XXD) -g 1 $< | head -n 8

clean:
	rm -rf $(BUILD_DIR)

-include $(OBJS:.o=.d)
